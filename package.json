{
  "name": "pinot-agents",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/monitor",
    "packages/operator",
    "packages/mitigator"
  ],
  "scripts": {
    "start": "npm start -w @pinot-agents/monitor",
    "start:operator": "npm start -w @pinot-agents/operator",
    "start:mitigator": "npm start -w @pinot-agents/mitigator",
    "start:all": "npm start -w @pinot-agents/monitor & npm start -w @pinot-agents/operator & npm start -w @pinot-agents/mitigator & wait",
    "typecheck": "tsc -b packages/shared packages/monitor packages/operator packages/mitigator",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
